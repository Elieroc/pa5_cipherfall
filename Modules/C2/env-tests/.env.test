# Test environment — local only, never deploy with these values
C2_PSK=testkey123
C2_POLL=2
C2_ADMIN_PORTS=1338,1337
C2_HOST=127.0.0.1

# NullRelay server talks to local wrangler dev
WORKER_URL=http://localhost:8787

# Docker agents reach host via host.docker.internal
WORKER_URL_DOCKER=http://host.docker.internal:8787
C2_DIRECT_DOCKER=host.docker.internal

# Fast beacon for tests
C2_INT=1
C2_JITTER=1
