# Copy to .env and fill in your values before running tui.py or server.py

# Cloudflare Worker URL (NullRelay channel)
WORKER_URL=https://your-worker.workers.dev

# Pre-shared key — must match on server, agent, and Worker secret
C2_PSK=changeme

# Admin API ports: NTP C2 first (1338), CF C2 second (1337)
# TUI polls all ports; omit a port if that server is not running
C2_ADMIN_PORTS=1338,1337

# Public IP of the C2 server (shown in graph view + NTP relay commands)
C2_HOST=0.0.0.0

# Server poll interval in seconds (dispatch + collect loop)
C2_POLL=3

# SQLite DB path — used by server.py, not the TUI
# C2_DB=/opt/operator_c2/c2.db
